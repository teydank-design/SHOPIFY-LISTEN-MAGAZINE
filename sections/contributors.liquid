{%- comment -%}
  Section masquée sur la boutique tant qu'aucun bloc n'est ajouté ;
  dans l'éditeur de thème, des carrés d'exemple s'affichent pour guider.
{%- endcomment -%}
{%- if section.blocks.size > 0 or request.design_mode -%}
<section class="contributors-section section--dark" id="contributeurs">
  <div class="container">

    <div style="margin-bottom: clamp(40px, 6vw, 72px);" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="t-label" style="color: var(--color-text-muted); margin-bottom: 12px;">
          {{- section.settings.eyebrow -}}
        </p>
      {%- endif -%}
      <h2 class="t-section">{{ section.settings.title | default: 'Contributeurs' }}</h2>
    </div>

    <!-- Contributors grid -->
    <div class="grid" style="row-gap: clamp(40px, 6vw, 64px);">
      {%- assign contributor_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'contributor' -%}
            {%- assign contributor_count = contributor_count | plus: 1 -%}
            <div
              class="contributor-card"
              style="grid-column: span 3;"
              data-reveal
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}" class="contributor-card__link" target="_blank" rel="noopener" aria-label="{{ block.settings.name | escape }}">
              {%- endif -%}

                {%- if block.settings.image != blank -%}
                  <div class="contributor-card__image">
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.name | escape }}"
                      width="300"
                      height="300"
                      loading="lazy"
                    >
                  </div>
                {%- else -%}
                  <div class="contributor-card__image" style="background: var(--color-bg-alt);"></div>
                {%- endif -%}

                <h3 class="contributor-card__name">{{ block.settings.name }}</h3>
                {%- if block.settings.role != blank -%}
                  <p class="contributor-card__role">{{ block.settings.role }}</p>
                {%- endif -%}

              {%- if block.settings.url != blank -%}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} Carrés d'exemple, visibles uniquement dans l'éditeur {%- endcomment -%}
      {%- if contributor_count == 0 and request.design_mode -%}
        {%- for i in (1..4) -%}
          <div class="contributor-card" style="grid-column: span 3;">
            <div class="contributor-card__image" style="background: var(--color-bg-alt); display:flex; align-items:center; justify-content:center;">
              <span class="t-label" style="color: var(--color-text-muted);">Image carrée</span>
            </div>
            <h3 class="contributor-card__name">Nom de l'artiste</h3>
            <p class="contributor-card__role">Rôle — ajoutez un bloc « Contributeur »</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Visual extracts -->
    {%- if section.settings.show_extracts -%}
      <div style="margin-top: clamp(60px, 8vw, 100px);" data-reveal>
        {%- assign extract_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'visual_extract' -%}
            {%- assign extract_count = extract_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if extract_count > 0 -%}
          <p class="t-label" style="color: var(--color-text-muted); margin-bottom: 24px;">
            Extraits visuels
          </p>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 4px;">
            {%- for block in section.blocks -%}
              {%- if block.type == 'visual_extract' -%}
                <div style="aspect-ratio: 3/4; overflow: hidden;" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.caption | escape }}"
                      width="300"
                      height="400"
                      loading="lazy"
                      style="width:100%; height:100%; object-fit:cover; filter: contrast(1.1) saturate(0.85);"
                    >
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Contributeurs",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texte au-dessus",
      "default": "N°0 Hybridation"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre de section",
      "default": "Contributeurs"
    },
    {
      "type": "checkbox",
      "id": "show_extracts",
      "label": "Afficher les extraits visuels",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "contributor",
      "name": "Contributeur",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo (carrée)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom",
          "default": "Nom de l'artiste"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Rôle (optionnel)",
          "default": "Photographe"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Lien au clic (Instagram, portfolio…)"
        }
      ]
    },
    {
      "type": "visual_extract",
      "name": "Extrait visuel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image extrait"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Légende (alt text)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contributeurs Listen"
    }
  ]
}
{% endschema %}
