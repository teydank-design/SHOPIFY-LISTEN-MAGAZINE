{%- comment -%}
  Lien produit : pointe directement vers la page produit (choisie via le
  picker "product_link"), sinon vers le premier produit de la boutique.
{%- endcomment -%}
{%- assign nav_product = all_products[section.settings.product_link] -%}
{%- if nav_product.url != blank -%}
  {%- assign product_url = nav_product.url -%}
{%- else -%}
  {%- assign product_url = collections.all.products.first.url | default: routes.root_url -%}
{%- endif -%}

{%- comment -%}
  Garde-fou : le lien À propos avait été renommé "BLOG" dans l'éditeur avant
  qu'un vrai lien Blog existe. S'il porte encore ce label, on le masque pour
  éviter un doublon avec le lien Blog dédié.
{%- endcomment -%}
{%- assign about_label = section.settings.about_link_label | default: 'À propos' -%}
{%- assign about_label_up = about_label | strip | upcase -%}
{%- assign show_about = section.settings.show_about_link -%}
{%- if about_label_up == 'BLOG' -%}
  {%- assign show_about = false -%}
{%- endif -%}

<nav class="site-nav" role="navigation" aria-label="Navigation principale">
  <a href="{{ routes.root_url }}" class="site-nav__logo" aria-label="{{ shop.name }}">
    {%- if section.settings.logo_image != blank -%}
      <img
        src="{{ section.settings.logo_image | image_url: width: 400 }}"
        alt="{{ shop.name }}"
        class="site-nav__logo-img"
        width="{{ section.settings.logo_image.width }}"
        height="{{ section.settings.logo_image.height }}"
      >
    {%- else -%}
      {%- comment -%}
        Garde-fou : si le réglage est vide ou trop court (ex. "." resté
        dans l'éditeur), on retombe sur ".LISTEN".
      {%- endcomment -%}
      {%- assign logo_line = section.settings.logo_text | strip -%}
      {%- if logo_line.size < 2 -%}
        {%- assign logo_line = '.LISTEN' -%}
      {%- endif -%}
      <span class="site-nav__logo-stack">
        <span>{{ logo_line }}</span>
        <span>{{ logo_line }}</span>
        <span>{{ logo_line }}</span>
      </span>
    {%- endif -%}
  </a>

  <ul class="site-nav__links">
    <li><a href="{{ routes.root_url }}">Accueil</a></li>
    {%- if section.settings.show_product_link -%}
      <li>
        <a href="{{ product_url }}">
          {{ section.settings.product_link_label | default: 'N°0 Hybridation' }}
        </a>
      </li>
    {%- endif -%}
    {%- if show_about -%}
      <li><a href="{{ routes.root_url }}#about">{{ about_label }}</a></li>
    {%- endif -%}
    {%- if section.settings.show_blog_link -%}
      <li>
        <a href="{{ section.settings.blog_url | default: 'https://listen-magazine.com' }}" target="_blank" rel="noopener">
          {{ section.settings.blog_link_label | default: 'Blog' }}
        </a>
      </li>
    {%- endif -%}
  </ul>

  <div class="site-nav__actions">
    <button class="btn btn--outline site-nav__cart" data-open-cart aria-label="Ouvrir le panier">
      Panier (<span data-cart-count>{{ cart.item_count }}</span>)
    </button>

    <button class="site-nav__burger" data-menu-open aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
      Menu
    </button>
  </div>
</nav>

<!-- Menu mobile plein écran (fond blanc) — hors du nav pour échapper au mix-blend-mode -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <button class="mobile-menu__close" data-menu-close aria-label="Fermer le menu">Fermer</button>

  <nav class="mobile-menu__links" aria-label="Menu mobile">
    <a href="{{ routes.root_url }}" data-menu-close>Accueil</a>
    {%- if section.settings.show_product_link -%}
      <a href="{{ product_url }}" data-menu-close>
        {{ section.settings.product_link_label | default: 'N°0 Hybridation' }}
      </a>
    {%- endif -%}
    {%- if show_about -%}
      <a href="{{ routes.root_url }}#about" data-menu-close>{{ about_label }}</a>
    {%- endif -%}
    {%- if section.settings.show_blog_link -%}
      <a href="{{ section.settings.blog_url | default: 'https://listen-magazine.com' }}" target="_blank" rel="noopener" data-menu-close>
        {{ section.settings.blog_link_label | default: 'Blog' }}
      </a>
    {%- endif -%}
    <button data-open-cart data-menu-close class="mobile-menu__cart">
      Panier (<span data-cart-count>{{ cart.item_count }}</span>)
    </button>
  </nav>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo (image)",
      "info": "Utiliser de préférence un logo blanc ou monochrome (PNG fond transparent) : la navigation s'affiche en incrustation et s'adapte automatiquement aux fonds clairs et sombres. Remplace le texte du logo si défini."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Texte du logo (si pas d'image)",
      "default": "Listen"
    },
    {
      "type": "checkbox",
      "id": "show_product_link",
      "label": "Afficher lien produit",
      "default": true
    },
    {
      "type": "text",
      "id": "product_link_label",
      "label": "Label lien produit",
      "default": "N°0 Hybridation"
    },
    {
      "type": "product",
      "id": "product_link",
      "label": "Produit lié (lien direct)"
    },
    {
      "type": "checkbox",
      "id": "show_about_link",
      "label": "Afficher lien À propos",
      "default": true
    },
    {
      "type": "text",
      "id": "about_link_label",
      "label": "Label À propos",
      "default": "À propos"
    },
    {
      "type": "checkbox",
      "id": "show_blog_link",
      "label": "Afficher lien Blog",
      "default": true
    },
    {
      "type": "text",
      "id": "blog_link_label",
      "label": "Label lien Blog",
      "default": "Blog"
    },
    {
      "type": "text",
      "id": "blog_url",
      "label": "URL du Blog",
      "default": "https://listen-magazine.com"
    }
  ]
}
{% endschema %}
