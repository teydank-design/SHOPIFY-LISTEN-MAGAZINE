<div class="cart-drawer__overlay" aria-hidden="true"></div>

<div class="cart-drawer" id="cart-drawer" role="dialog" aria-modal="true" aria-label="Panier">
  <div class="cart-drawer__header">
    <span class="cart-drawer__title">Panier</span>
    <button class="cart-drawer__close" aria-label="Fermer le panier">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.5"/>
        <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </button>
  </div>

  <div class="cart-drawer__body" style="padding: 24px;">
    {%- if cart.item_count == 0 -%}
      <p class="t-label" style="color: var(--color-text-muted); padding: 40px 0; text-align: center;">
        Votre panier est vide
      </p>
    {%- else -%}
      {%- for item in cart.items -%}
        <div class="cart-item" style="display:flex; gap:16px; padding:20px 0; border-bottom: 1px solid rgba(255,255,255,0.08);">
          <div style="width:72px; height:96px; overflow:hidden; flex-shrink:0;">
            <img src="{{ item.image | image_url: width: 144 }}" alt="{{ item.title | escape }}"
                 width="72" height="96" style="width:100%; height:100%; object-fit:cover;">
          </div>
          <div style="flex:1;">
            <p class="t-label" style="margin-bottom:4px;">{{ item.product.title }}</p>
            <p class="t-caption" style="color:var(--color-text-muted); margin-bottom:12px;">{{ item.variant.title }}</p>
            <p class="t-subtitle">{{ item.final_price | money }}</p>
          </div>
          <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0"
             class="t-label" style="color:var(--color-text-muted); align-self:flex-start;">
            Retirer
          </a>
        </div>
      {%- endfor -%}

      <div style="padding: 24px 0;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
          <span class="t-label">Total</span>
          <span class="t-subtitle">{{ cart.total_price | money }}</span>
        </div>
        <a href="{{ routes.checkout }}" class="btn btn--primary btn--buy">
          Commander — {{ cart.total_price | money }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>
