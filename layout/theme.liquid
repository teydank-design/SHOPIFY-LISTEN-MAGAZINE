<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FFFFFF">

  <title>
    {%- if template == 'index' -%}
      {{ shop.name }} — N°0 Hybridation
    {%- elsif page_title == blank -%}
      {{ shop.name }}
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ page_title | default: shop.name }}">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
    <meta property="og:image:width" content="1200">
  {%- endif -%}
  <meta property="og:url" content="{{ canonical_url }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- GSAP (CDN) — SplitText retiré : jamais utilisé dans theme.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

  {{ content_for_header }}
</head>

<body class="template-{{ template | replace: '.', '-' }}">

  <!-- Accessibilité : aller directement au contenu -->
  <a class="skip-link" href="#main-content">Aller au contenu</a>

  <!-- Grain overlay — soul of Listen -->
  {%- render 'grain-overlay' -%}

  <!-- Custom cursor (hidden on mobile via CSS) -->
  {%- render 'cursor-custom' -%}

  <!-- Intro loader (homepage only) -->
  {%- if template == 'index' -%}
    {%- render 'intro-loader' -%}
  {%- endif -%}

  <!-- Cart drawer -->
  {%- render 'cart-drawer' -%}

  <!-- Navigation -->
  {%- section 'header' -%}

  <!-- Page content -->
  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {%- section 'footer' -%}

  <!-- Theme JS -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

</body>
</html>
